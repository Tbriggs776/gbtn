# Copy this file to `.env.local` and fill in the values from your Supabase project.
# NEVER commit `.env.local`. The service-role key is a secret — keep it server-side.

# Supabase → Project Settings → Data API / API Keys
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key

# Supabase → Project Settings → API Keys → service_role (SECRET — server only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Public base URL of the site (used to build invite/redirect links).
# Local dev: http://localhost:3000 — set to your real domain in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (https://resend.com) — sends all app-originated email: contact-form
# alerts and "new financials are ready" client notifications. Without a key,
# those records are still SAVED (contact submissions / financials); only the
# email step is skipped. NOTE: Supabase AUTH emails (invites, password resets,
# magic links) are sent by Supabase, not this key — route those through Resend
# via Supabase → Authentication → Custom SMTP (see SETUP.md).
RESEND_API_KEY=your-resend-api-key
# System sender for app email. Must be a Resend-VERIFIED domain to deliver to
# arbitrary recipients (e.g. clients). Until growthbythenumbers.com is verified,
# leave unset to use Resend's shared test sender (reaches only your signup email).
# EMAIL_FROM=Growth by the Numbers <noreply@growthbythenumbers.com>
# Optional. Where contact-form/admin notifications land (default tyler.briggs@outlook.com).
# CONTACT_NOTIFY_TO=tyler.briggs@outlook.com

# Secret that protects the daily marketing sync cron (/api/cron/marketing-sync).
# Set the SAME value in Vercel → Settings → Environment Variables; Vercel Cron
# sends it automatically as the Authorization header. Use a long random string.
CRON_SECRET=your-long-random-cron-secret
