# Copy this file to `.env.local` and fill in the values from your Supabase project.
# NEVER commit `.env.local`. The service-role key is a secret — keep it server-side.

# Supabase → Project Settings → Data API / API Keys
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key

# Supabase → Project Settings → API Keys → service_role (SECRET — server only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Public base URL of the site (used to build invite/redirect links).
# Local dev: http://localhost:3000 — set to your real domain in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (https://resend.com) — sends a notification email when someone submits
# the contact form. Without these, submissions are still SAVED to the database
# and visible in the portal Admin page; only the email notification is skipped.
RESEND_API_KEY=your-resend-api-key
# Optional. Verified Resend sender. Until you verify growthbythenumbers.com in
# Resend, leave this unset to use Resend's shared testing sender.
# CONTACT_FROM_EMAIL=Growth by the Numbers <noreply@growthbythenumbers.com>
# Optional. Where lead notifications are sent (defaults to tyler.briggs@outlook.com).
# CONTACT_NOTIFY_TO=tyler.briggs@outlook.com
